---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import { LANGS, type Lang } from '../../../lib/site';
import { t } from '../../../i18n/ui';
import { asset } from '../../../lib/assets';
import { localePath } from '../../../lib/paths';

export const getStaticPaths = async () => {
  const projects = await getCollection('projects');
  return LANGS.flatMap((lang) =>
    projects.map((p) => ({
      params: { lang, slug: p.data.slug },
      props: { project: p, projects },
    }))
  );
};

const lang = Astro.params.lang as Lang;
const { project, projects } = Astro.props as {
  project: Awaited<ReturnType<typeof getCollection<'projects'>>>[number];
  projects: Awaited<ReturnType<typeof getCollection<'projects'>>>;
};

const tr = project.data.i18n[lang];
const ordered = [...projects].sort((a, b) => a.data.order - b.data.order);
const idx = ordered.findIndex((p) => p.data.slug === project.data.slug);
const num = String(idx + 1).padStart(2, '0');
const next = ordered[(idx + 1) % ordered.length];
const nextTr = next.data.i18n[lang];
const nextNum = String(((idx + 1) % ordered.length) + 1).padStart(2, '0');
---

<BaseLayout lang={lang} title={tr.title} description={tr.description}>
  <Nav lang={lang} />
  <main id="contenido">
    <article>
      <header class="border-b border-ink/10 bg-paper">
        <div class="container-w pt-14 pb-16 sm:pt-20 sm:pb-20">
          <a
            href={`${localePath(lang)}#obras`}
            class="inline-flex items-center gap-2 font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted hover:text-ink"
          >
            <span aria-hidden="true">←</span> {t('projects.back', lang)}
          </a>

          <div class="mt-10 grid gap-8 sm:grid-cols-12 sm:items-end">
            <div class="sm:col-span-9">
              <span class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-faint">[{num}]</span>
              <h1 class="mt-4 h-display text-balance">{tr.title}</h1>
            </div>
            <div class="sm:col-span-3 sm:text-right">
              <p class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted capitalize">
                {project.data.type}
              </p>
            </div>
          </div>

          <dl class="mt-12 grid grid-cols-2 gap-x-6 gap-y-8 border-t border-ink/15 pt-8 sm:grid-cols-3 sm:max-w-2xl">
            <div>
              <dt class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">{t('projects.location', lang)}</dt>
              <dd class="mt-2 font-display text-fluid-base text-ink">{tr.location}</dd>
            </div>
            <div>
              <dt class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">{t('projects.year', lang)}</dt>
              <dd class="mt-2 font-display text-fluid-base text-ink">{project.data.year}</dd>
            </div>
            <div>
              <dt class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">{t('projects.type', lang)}</dt>
              <dd class="mt-2 font-display text-fluid-base text-ink capitalize">{project.data.type}</dd>
            </div>
          </dl>
        </div>
      </header>

      <section class="container-w py-16 sm:py-20">
        <p class="lead text-pretty">{tr.description}</p>
      </section>

      <section class="container-w pb-20 sm:pb-28">
        <h2 class="sr-only">{t('projects.gallery', lang)}</h2>
        <div class="grid gap-5 sm:gap-7">
          {
            project.data.images.map((img, i) => (
              <figure class="bg-paper-soft">
                <img
                  src={asset(img)}
                  alt={`${tr.title} — ${i + 1}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="h-auto w-full"
                />
              </figure>
            ))
          }
        </div>
      </section>

      <nav class="border-t border-ink/15 bg-paper-soft" aria-label="Project navigation">
        <a
          href={localePath(lang, 'proyecto', next.data.slug)}
          class="container-w group flex items-end justify-between gap-6 py-10 sm:py-12"
        >
          <div>
            <p class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">
              {t('projects.next', lang)} <span class="text-ink-faint">[{nextNum}]</span>
            </p>
            <p class="mt-3 font-display text-fluid-xl font-light tracking-tightest text-ink">{nextTr.title}</p>
          </div>
          <span class="font-display text-fluid-xl font-light text-ink transition-transform group-hover:translate-x-1">→</span>
        </a>
      </nav>
    </article>
  </main>
  <Footer lang={lang} />
</BaseLayout>
