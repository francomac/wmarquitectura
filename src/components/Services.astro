---
import type { Lang } from '../lib/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const items = [
  { key: 'design', num: '01' },
  { key: 'renovation', num: '02' },
  { key: 'construction', num: '03' },
  { key: 'consulting', num: '04' },
] as const;
---

<section id="servicios" class="border-t border-ink/10 bg-paper">
  <div class="container-w py-20 sm:py-28">
    <header class="mb-14 grid gap-6 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-8">
        <span class="eyebrow">
          <span class="eyebrow-num">[03]</span>
          {t('services.title', lang)}
        </span>
        <h2 class="mt-6 h-section text-balance">{t('services.subtitle', lang)}</h2>
      </div>
    </header>

    <ul class="grid border-y border-ink/15 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map((it, idx) => (
          <li
            class={`group relative px-0 py-8 sm:px-7 sm:py-10 ${
              idx > 0 ? 'border-t border-ink/15 sm:border-t-0 sm:border-l' : ''
            } ${idx >= 2 ? 'lg:border-l lg:border-t-0' : ''}`}
          >
            <div class="flex items-baseline justify-between">
              <span class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">
                {it.num}
              </span>
              <span class="font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-faint">
                Servicio
              </span>
            </div>
            <h3 class="mt-8 font-display text-fluid-lg font-light tracking-tightest text-ink leading-tight">
              {t(`services.items.${it.key}.title`, lang)}
            </h3>
            <p class="mt-4 text-fluid-sm leading-[1.55] text-ink-muted">
              {t(`services.items.${it.key}.description`, lang)}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
