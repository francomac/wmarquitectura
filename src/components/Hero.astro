---
import type { Lang } from '../lib/site';
import { SITE } from '../lib/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/paths';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const home = localePath(lang);
---

<section class="relative overflow-hidden bg-paper">
  <div class="container-w pt-14 pb-20 sm:pt-20 sm:pb-28 lg:pt-28 lg:pb-36">
    <div class="grid items-end gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-7">
        <span class="eyebrow">
          {t('hero.eyebrow', lang)}
        </span>
        <h1 class="mt-8 h-display text-balance">
          {t('hero.title', lang)}
        </h1>
        <p class="mt-10 lead text-pretty">
          {t('hero.subtitle', lang)}
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href={`${home}#obras`} class="btn-primary">{t('hero.ctaProjects', lang)} <span aria-hidden="true">↓</span></a>
          <a href={`${home}#contacto`} class="btn-ghost">{t('hero.ctaContact', lang)}</a>
        </div>
      </div>

      <aside class="lg:col-span-5">
        <figure class="relative">
          <div class="aspect-[4/5] w-full overflow-hidden bg-paper-soft">
            <img
              src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=1200&q=80"
              alt="Casa tropical con madera y vidrio en el Pacífico Sur de Costa Rica"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
          <figcaption class="mt-4 flex flex-col gap-1.5 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
            <div class="font-mono text-fluid-xs uppercase tracking-[0.18em] text-ink-muted">
              {SITE.region}
            </div>
            <span class="font-mono text-fluid-xs uppercase tracking-[0.18em] text-ink-muted">
              Est. {SITE.yearFounded}
            </span>
          </figcaption>
        </figure>
      </aside>
    </div>
  </div>

  <div class="rule"></div>

  <div class="container-w">
    <div class="grid grid-cols-2 sm:grid-cols-4 divide-x divide-ink/10 -mx-5 sm:-mx-8 lg:-mx-14">
      <div class="px-5 sm:px-8 lg:px-10 py-7">
        <p class="font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-muted">Años</p>
        <p class="mt-2 font-display text-fluid-xl font-light leading-none tracking-tightest">20<span class="text-ink-faint">+</span></p>
      </div>
      <div class="px-5 sm:px-8 lg:px-10 py-7">
        <p class="font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-muted">Obras</p>
        <p class="mt-2 font-display text-fluid-xl font-light leading-none tracking-tightest">100<span class="text-ink-faint">+</span></p>
      </div>
      <div class="px-5 sm:px-8 lg:px-10 py-7">
        <p class="font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-muted">Base</p>
        <p class="mt-2 font-display text-fluid-lg font-light leading-none tracking-tightest">Dominical</p>
      </div>
      <div class="px-5 sm:px-8 lg:px-10 py-7">
        <p class="font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-muted">Práctica</p>
        <p class="mt-2 font-display text-fluid-lg font-light leading-none tracking-tightest">Independiente</p>
      </div>
    </div>
  </div>
</section>
