---
import { LANGS, LANG_LABELS, type Lang } from '../lib/site';
import { swapLocaleInPath } from '../lib/paths';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav
  aria-label={t('common.changeLanguage', lang)}
  class="flex items-center font-mono text-[0.65rem] uppercase tracking-[0.18em]"
>
  {
    LANGS.map((l, i) => {
      const active = l === lang;
      const href = swapLocaleInPath(currentPath, l);
      return (
        <>
          {i > 0 && <span class="px-1.5 text-ink-faint" aria-hidden="true">·</span>}
          <a
            href={href}
            aria-current={active ? 'true' : undefined}
            class={`transition-colors ${
              active ? 'text-ink font-medium' : 'text-ink-muted hover:text-ink'
            }`}
          >
            {LANG_LABELS[l]}
          </a>
        </>
      );
    })
  }
</nav>
