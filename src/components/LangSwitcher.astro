---
import { LANGS, LANG_LABELS, type Lang } from '../lib/site';
import { swapLocaleInPath } from '../lib/paths';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav aria-label={t('common.changeLanguage', lang)} class="flex items-center gap-1 text-xs font-medium">
  {
    LANGS.map((l) => {
      const active = l === lang;
      const href = swapLocaleInPath(currentPath, l);
      return (
        <a
          href={href}
          aria-current={active ? 'true' : undefined}
          class={`rounded-full px-2.5 py-1 transition-colors ${
            active
              ? 'bg-ink text-paper'
              : 'text-ink-muted hover:text-ink'
          }`}
        >
          {LANG_LABELS[l]}
        </a>
      );
    })
  }
</nav>
