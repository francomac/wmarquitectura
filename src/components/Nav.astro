---
import { SITE, type Lang } from '../lib/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/paths';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const home = localePath(lang);

const links = [
  { href: `${home}#proyectos`, label: t('nav.projects', lang) },
  { href: `${home}#sobre-mi`, label: t('nav.about', lang) },
  { href: `${home}#servicios`, label: t('nav.services', lang) },
  { href: `${home}#contacto`, label: t('nav.contact', lang) },
];
---

<header class="sticky top-0 z-40 border-b border-ink/5 bg-paper/80 backdrop-blur-md">
  <div class="container-w flex h-16 items-center justify-between gap-4 sm:h-20">
    <a href={home} class="flex items-baseline gap-2 font-display text-lg sm:text-xl tracking-tight">
      <span class="font-medium">{SITE.name}</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class="link-underline text-ink/80 hover:text-ink">{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <LangSwitcher lang={lang} />
      <button
        type="button"
        class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-ink/15 text-ink"
        aria-label={t('common.openMenu', lang)}
        aria-expanded="false"
        data-nav-toggle
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" data-menu-bars />
          <path d="M6 6l12 12M18 6L6 18" data-menu-close class="hidden" />
        </svg>
      </button>
    </div>
  </div>

  <div
    class="md:hidden hidden border-t border-ink/5 bg-paper"
    data-nav-panel
    id="mobile-nav"
  >
    <nav class="container-w flex flex-col gap-1 py-4 text-base" aria-label="Mobile">
      {links.map((l) => (
        <a
          href={l.href}
          class="py-3 text-ink/80 hover:text-ink border-b border-ink/5 last:border-b-0"
          data-nav-link
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-nav-panel]');
  const bars = document.querySelector<SVGPathElement>('[data-menu-bars]');
  const close = document.querySelector<SVGPathElement>('[data-menu-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');

  const setOpen = (open: boolean) => {
    if (!toggle || !panel || !bars || !close) return;
    toggle.setAttribute('aria-expanded', String(open));
    panel.classList.toggle('hidden', !open);
    bars.classList.toggle('hidden', open);
    close.classList.toggle('hidden', !open);
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!open);
  });

  links.forEach((l) => l.addEventListener('click', () => setOpen(false)));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
