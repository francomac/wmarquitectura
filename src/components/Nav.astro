---
import { SITE, type Lang } from '../lib/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/paths';
import LangSwitcher from './LangSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const home = localePath(lang);

const links = [
  { href: `${home}#obras`, label: t('nav.projects', lang) },
  { href: `${home}#estudio`, label: t('nav.about', lang) },
  { href: `${home}#servicios`, label: t('nav.services', lang) },
  { href: `${home}#contacto`, label: t('nav.contact', lang) },
];
---

<header class="sticky top-0 z-40 border-b border-ink/10 bg-paper/85 backdrop-blur-md">
  <div class="container-w flex h-[68px] items-center justify-between gap-4 sm:h-[80px]">
    <a href={home} class="group flex items-baseline gap-3">
      <span class="font-display text-xl sm:text-[1.45rem] font-light leading-none tracking-tightest text-ink">
        William Martínez
      </span>
      <span class="hidden sm:inline-block h-3 w-px bg-ink/30"></span>
      <span class="hidden sm:inline-block font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-muted">
        Arquitecto
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-9 text-sm" aria-label="Primary">
      {
        links.map((l) => (
          <a href={l.href} class="link-underline font-medium text-ink/85 hover:text-ink">
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <LangSwitcher lang={lang} />
      <button
        type="button"
        class="md:hidden inline-flex h-10 w-10 items-center justify-center border border-ink/20 text-ink"
        aria-label={t('common.openMenu', lang)}
        aria-expanded="false"
        data-nav-toggle
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
          <path d="M4 8h16M4 16h16" data-menu-bars />
          <path d="M6 6l12 12M18 6L6 18" data-menu-close class="hidden" />
        </svg>
      </button>
    </div>
  </div>

  <div class="md:hidden hidden border-t border-ink/10 bg-paper" data-nav-panel id="mobile-nav">
    <nav class="container-w flex flex-col py-2" aria-label="Mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="border-b border-ink/10 py-4 text-base text-ink/85 last:border-b-0 hover:text-ink"
            data-nav-link
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-nav-panel]');
  const bars = document.querySelector<SVGPathElement>('[data-menu-bars]');
  const close = document.querySelector<SVGPathElement>('[data-menu-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');

  const setOpen = (open: boolean) => {
    if (!toggle || !panel || !bars || !close) return;
    toggle.setAttribute('aria-expanded', String(open));
    panel.classList.toggle('hidden', !open);
    bars.classList.toggle('hidden', open);
    close.classList.toggle('hidden', !open);
  };

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!open);
  });

  links.forEach((l) => l.addEventListener('click', () => setOpen(false)));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
