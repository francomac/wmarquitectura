---
import type { Lang } from '../lib/site';
import { SITE } from '../lib/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="estudio" class="border-t border-ink/10 bg-paper-soft">
  <div class="container-w py-20 sm:py-28">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-5">
        <figure class="relative">
          <div class="aspect-[4/5] w-full overflow-hidden bg-ink/5">
            <img
              src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=1200&q=80"
              alt="Planos arquitectónicos sobre mesa de trabajo"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
          <figcaption class="mt-4 font-mono text-fluid-xs uppercase tracking-[0.18em] text-ink-muted">
            Estudio — {SITE.base}
          </figcaption>
        </figure>
      </div>

      <div class="lg:col-span-7 flex flex-col justify-center">
        <span class="eyebrow">
          <span class="eyebrow-num">[02]</span>
          {t('about.title', lang)}
        </span>
        <h2 class="mt-6 h-section text-balance">{t('about.title', lang)}</h2>
        <p class="mt-8 lead text-pretty">
          {t('about.body', lang)}
        </p>

        <dl class="mt-12 grid grid-cols-2 gap-x-6 gap-y-8 border-t border-ink/15 pt-10 sm:grid-cols-3 sm:max-w-xl">
          <div>
            <dt class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">Base</dt>
            <dd class="mt-2 font-display text-fluid-base text-ink">{SITE.base}</dd>
          </div>
          <div>
            <dt class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">Región</dt>
            <dd class="mt-2 font-display text-fluid-base text-ink">{SITE.region}</dd>
          </div>
          <div>
            <dt class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">Desde</dt>
            <dd class="mt-2 font-display text-fluid-base text-ink">{SITE.yearFounded}</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
