---
import type { Lang } from '../lib/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="sobre-mi" class="border-b border-ink/5 bg-paper-soft">
  <div class="container-w grid gap-10 py-16 sm:py-24 lg:grid-cols-12 lg:gap-16">
    <div class="lg:col-span-5">
      <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-ink/5">
        <img
          src="https://images.unsplash.com/photo-1531123897727-8f129e1688ce?auto=format&fit=crop&w=1200&q=80"
          alt="Retrato del arquitecto"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
    <div class="lg:col-span-7 flex flex-col justify-center">
      <span class="eyebrow">{t('about.title', lang)}</span>
      <h2 class="mt-3 h-section">{t('about.title', lang)}</h2>
      <p class="mt-6 max-w-prose text-fluid-base leading-relaxed text-ink-muted">
        {t('about.body', lang)}
      </p>
    </div>
  </div>
</section>
