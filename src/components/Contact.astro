---
import { SITE, type Lang } from '../lib/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const channels = [
  {
    label: t('contact.whatsapp', lang),
    value: SITE.contact.phone,
    href: SITE.contact.whatsappLink,
  },
  {
    label: t('contact.instagram', lang),
    value: SITE.contact.instagramHandle,
    href: SITE.contact.instagramLink,
  },
  {
    label: t('contact.facebook', lang),
    value: SITE.contact.facebookName,
    href: SITE.contact.facebookLink,
  },
];
---

<section id="contacto" class="bg-ink text-paper">
  <div class="container-w py-20 sm:py-28">
    <header class="grid gap-8 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-8">
        <span class="inline-flex items-center gap-2 font-mono text-fluid-xs uppercase tracking-eyebrow text-paper/60">
          <span class="text-paper/40">[05]</span>
          {t('contact.title', lang)}
        </span>
        <h2 class="mt-6 font-display font-light text-fluid-2xl leading-[1.02] tracking-tightest text-balance">
          {t('contact.subtitle', lang)}
        </h2>
      </div>
      <div class="sm:col-span-4 sm:text-right">
        <p class="font-mono text-fluid-xs uppercase tracking-eyebrow text-paper/60">
          {SITE.base}
        </p>
      </div>
    </header>

    <ul class="mt-14 grid border-y border-paper/15 sm:grid-cols-3">
      {
        channels.map((c, i) => (
          <li class={i > 0 ? 'border-t border-paper/15 sm:border-t-0 sm:border-l' : ''}>
            <a
              href={c.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex h-full items-center justify-between gap-4 px-0 py-8 sm:px-7 sm:py-10 transition-colors hover:bg-ink-soft"
            >
              <div>
                <p class="font-mono text-fluid-xs uppercase tracking-eyebrow text-paper/60">{c.label}</p>
                <p class="mt-3 font-display text-fluid-lg font-light tracking-tightest">{c.value}</p>
              </div>
              <span class="inline-flex h-9 w-9 items-center justify-center border border-paper/30 transition-all group-hover:border-paper group-hover:translate-x-0.5">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7M9 7h8v8" />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
