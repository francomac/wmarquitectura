---
import { SITE, type Lang } from '../lib/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const channels = [
  {
    label: t('contact.whatsapp', lang),
    value: SITE.contact.phone,
    href: SITE.contact.whatsappLink,
    icon: 'whatsapp',
  },
  {
    label: t('contact.instagram', lang),
    value: SITE.contact.instagramHandle,
    href: SITE.contact.instagramLink,
    icon: 'instagram',
  },
  {
    label: t('contact.facebook', lang),
    value: SITE.contact.facebookName,
    href: SITE.contact.facebookLink,
    icon: 'facebook',
  },
];
---

<section id="contacto" class="bg-ink text-paper">
  <div class="container-w py-16 sm:py-24">
    <header class="max-w-2xl">
      <span class="inline-block text-[0.7rem] uppercase tracking-[0.22em] text-paper/60">{t('contact.title', lang)}</span>
      <h2 class="mt-3 font-display text-fluid-2xl leading-tight tracking-tight">{t('contact.subtitle', lang)}</h2>
    </header>

    <ul class="mt-10 grid gap-px overflow-hidden rounded-2xl border border-paper/15 bg-paper/10 sm:grid-cols-3">
      {
        channels.map((c) => (
          <li class="bg-ink">
            <a
              href={c.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex h-full items-center justify-between gap-4 p-6 transition-colors hover:bg-ink-soft"
            >
              <div>
                <p class="text-xs uppercase tracking-widest text-paper/60">{c.label}</p>
                <p class="mt-2 font-display text-fluid-lg">{c.value}</p>
              </div>
              <span class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-paper/30 transition-colors group-hover:border-paper">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7M9 7h8v8" />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
