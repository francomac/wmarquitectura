---
import { SITE, type Lang } from '../lib/site';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = 2026;
---

<footer class="bg-paper">
  <div class="container-w py-12 sm:py-14">
    <div class="grid gap-8 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-6">
        <p class="font-display text-fluid-lg font-light tracking-tightest text-ink">{SITE.fullName}</p>
        <p class="mt-2 font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">
          {SITE.tagline} · {SITE.base}
        </p>
      </div>
      <div class="sm:col-span-6 sm:text-right">
        <div class="flex flex-wrap items-center gap-5 sm:justify-end font-mono text-fluid-xs uppercase tracking-[0.18em] text-ink-muted">
          <a href={SITE.contact.instagramLink} target="_blank" rel="noopener noreferrer" class="link-underline">Instagram</a>
          <a href={SITE.contact.whatsappLink} target="_blank" rel="noopener noreferrer" class="link-underline">WhatsApp</a>
          <a href={SITE.contact.emailLink} class="link-underline">{t('contact.email', lang)}</a>
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-ink/15 pt-6">
      <p class="font-mono text-[0.65rem] uppercase tracking-eyebrow text-ink-faint">
        © {year} {SITE.fullName}. {t('footer.rights', lang)}
      </p>
    </div>
  </div>
</footer>
