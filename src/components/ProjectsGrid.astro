---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../lib/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/paths';
import { asset } from '../lib/assets';

interface Props {
  lang: Lang;
  projects: CollectionEntry<'projects'>[];
}

const { lang, projects } = Astro.props;
const sorted = [...projects].sort((a, b) => a.data.order - b.data.order);
---

<section id="obras" class="border-t border-ink/10 bg-paper">
  <div class="container-w pt-20 pb-24 sm:pt-28 sm:pb-32">
    <header class="mb-12 sm:mb-16 grid gap-6 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-8">
        <span class="eyebrow">
          <span class="eyebrow-num">[01]</span>
          {t('projects.title', lang)}
        </span>
        <h2 class="mt-6 h-section text-balance">{t('projects.subtitle', lang)}</h2>
      </div>
      <div class="sm:col-span-4 sm:text-right">
        <p class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted">
          {sorted.length} {sorted.length === 1 ? 'obra' : 'obras'}
        </p>
      </div>
    </header>

    <div class="columns-1 gap-5 sm:columns-2 sm:gap-7 lg:columns-3">
      {
        sorted.map((p, i) => {
          const tr = p.data.i18n[lang];
          const num = String(i + 1).padStart(2, '0');
          return (
            <a
              href={localePath(lang, 'proyecto', p.data.slug)}
              class="group mb-5 sm:mb-7 block break-inside-avoid"
            >
              <div class="relative overflow-hidden bg-paper-soft">
                <img
                  src={asset(p.data.cover)}
                  alt={p.data.coverAlt ?? tr.title}
                  loading="lazy"
                  decoding="async"
                  class="h-auto w-full transition-transform duration-[900ms] ease-out group-hover:scale-[1.04]"
                />
                <span class="pointer-events-none absolute left-4 top-4 font-mono text-[0.65rem] uppercase tracking-eyebrow text-paper mix-blend-difference">
                  {num}
                </span>
              </div>
              <div class="mt-4 flex items-baseline justify-between gap-4">
                <div class="min-w-0">
                  <h3 class="font-display text-fluid-lg font-light tracking-tightest text-ink leading-tight">
                    {tr.title}
                  </h3>
                  <p class="mt-1.5 font-mono text-fluid-xs uppercase tracking-[0.18em] text-ink-muted">
                    <span>{tr.location}</span>
                    <span class="text-ink-faint"> · </span>
                    <span>{p.data.year}</span>
                  </p>
                </div>
                <span class="shrink-0 text-ink-faint transition-all group-hover:translate-x-1 group-hover:text-ink">
                  →
                </span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
