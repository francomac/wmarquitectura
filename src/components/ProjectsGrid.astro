---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../lib/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/paths';
import { asset } from '../lib/assets';

interface Props {
  lang: Lang;
  projects: CollectionEntry<'projects'>[];
}

const { lang, projects } = Astro.props;
const sorted = [...projects].sort((a, b) => a.data.order - b.data.order);
---

<section id="proyectos" class="border-b border-ink/5 bg-paper">
  <div class="container-w py-16 sm:py-24">
    <header class="mb-10 sm:mb-14 flex items-end justify-between gap-6">
      <div>
        <span class="eyebrow">{t('projects.title', lang)}</span>
        <h2 class="mt-3 h-section">{t('projects.subtitle', lang)}</h2>
      </div>
    </header>

    <div class="columns-1 gap-4 sm:columns-2 sm:gap-6 lg:columns-3">
      {
        sorted.map((p) => {
          const tr = p.data.i18n[lang];
          return (
            <a
              href={localePath(lang, 'proyecto', p.data.slug)}
              class="group mb-4 sm:mb-6 block break-inside-avoid overflow-hidden rounded-xl bg-paper-soft"
            >
              <div class="relative overflow-hidden">
                <img
                  src={asset(p.data.cover)}
                  alt={p.data.coverAlt ?? tr.title}
                  loading="lazy"
                  decoding="async"
                  class="h-auto w-full transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/40 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
              </div>
              <div class="flex items-baseline justify-between gap-4 px-4 py-3 sm:px-5 sm:py-4">
                <div>
                  <h3 class="font-display text-fluid-lg text-ink">{tr.title}</h3>
                  <p class="mt-1 text-xs text-ink-muted">{tr.location} · {p.data.year}</p>
                </div>
                <span class="text-xs text-ink-muted opacity-0 transition-opacity group-hover:opacity-100">→</span>
              </div>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
