---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../lib/site';
import { t } from '../i18n/ui';
import { localePath } from '../lib/paths';
import { asset } from '../lib/assets';

interface Props {
  lang: Lang;
  projects: CollectionEntry<'projects'>[];
}

const { lang, projects } = Astro.props;
const sorted = [...projects].sort((a, b) => a.data.order - b.data.order);
const total = String(sorted.length).padStart(2, '0');
---

<section id="obras" class="border-t border-ink/10 bg-paper">
  <div class="container-w pt-20 pb-24 sm:pt-28 sm:pb-32">
    <header class="mb-12 sm:mb-14 grid gap-6 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-7">
        <span class="eyebrow">
          <span class="eyebrow-num">[01]</span>
          {t('projects.title', lang)}
        </span>
        <h2 class="mt-6 h-section text-balance">{t('projects.subtitle', lang)}</h2>
      </div>

      <div class="sm:col-span-5 flex items-end justify-between gap-6 sm:justify-end">
        <p class="font-mono text-fluid-xs uppercase tracking-eyebrow text-ink-muted whitespace-nowrap">
          <span data-carousel-current>01</span>
          <span class="text-ink-faint"> / </span>
          <span>{total}</span>
        </p>

        <div class="flex items-center gap-2" role="group" aria-label="Navegación de obras">
          <button
            type="button"
            data-carousel-prev
            class="inline-flex h-11 w-11 items-center justify-center border border-ink/25 text-ink transition-all hover:border-ink hover:bg-ink hover:text-paper disabled:cursor-not-allowed disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-ink"
            aria-label="Anterior"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 6l-6 6 6 6" />
            </svg>
          </button>
          <button
            type="button"
            data-carousel-next
            class="inline-flex h-11 w-11 items-center justify-center border border-ink/25 text-ink transition-all hover:border-ink hover:bg-ink hover:text-paper disabled:cursor-not-allowed disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-ink"
            aria-label="Siguiente"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 6l6 6-6 6" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="obras-carousel" data-carousel>
      {
        sorted.map((p, i) => {
          const tr = p.data.i18n[lang];
          const num = String(i + 1).padStart(2, '0');
          return (
            <a
              href={localePath(lang, 'proyecto', p.data.slug)}
              class="group obras-card block"
              data-carousel-item
            >
              <div class="relative aspect-[4/5] overflow-hidden bg-paper-soft">
                <img
                  src={asset(p.data.cover)}
                  alt={p.data.coverAlt ?? tr.title}
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="h-full w-full object-cover transition-transform duration-[900ms] ease-out group-hover:scale-[1.04]"
                />
                <span class="pointer-events-none absolute left-4 top-4 font-mono text-[0.65rem] uppercase tracking-eyebrow text-paper mix-blend-difference">
                  {num}
                </span>
              </div>
              <div class="mt-4 flex items-baseline justify-between gap-3">
                <div class="min-w-0">
                  <h3 class="truncate font-display text-fluid-lg font-light tracking-tightest text-ink leading-tight">
                    {tr.title}
                  </h3>
                  <p class="mt-1.5 truncate font-mono text-fluid-xs uppercase tracking-[0.18em] text-ink-muted">
                    <span>{tr.location}</span>
                    <span class="text-ink-faint"> · </span>
                    <span>{p.data.year}</span>
                  </p>
                </div>
                <span class="shrink-0 text-ink-faint transition-all group-hover:translate-x-1 group-hover:text-ink">
                  →
                </span>
              </div>
            </a>
          );
        })
      }
    </div>

    <div class="mt-10 sm:mt-12">
      <div class="relative h-px w-full bg-ink/10">
        <div
          class="absolute top-0 left-0 h-px bg-ink transition-all duration-300 ease-out"
          data-carousel-progress
          style="width: 33.33%"
        ></div>
      </div>
    </div>
  </div>
</section>

<style>
  .obras-carousel {
    --gap: 1.25rem;
    display: flex;
    gap: var(--gap);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 0.25rem;
  }
  .obras-carousel::-webkit-scrollbar {
    display: none;
  }
  .obras-card {
    flex: 0 0 calc((100% - 2 * var(--gap)) / 3);
    scroll-snap-align: start;
  }
  @media (min-width: 640px) {
    .obras-carousel {
      --gap: 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .obras-carousel {
      --gap: 2rem;
    }
  }
</style>

<script>
  const carousel = document.querySelector<HTMLElement>('[data-carousel]');
  const prevBtn = document.querySelector<HTMLButtonElement>('[data-carousel-prev]');
  const nextBtn = document.querySelector<HTMLButtonElement>('[data-carousel-next]');
  const items = document.querySelectorAll<HTMLAnchorElement>('[data-carousel-item]');
  const currentEl = document.querySelector<HTMLElement>('[data-carousel-current]');
  const progressEl = document.querySelector<HTMLElement>('[data-carousel-progress]');

  if (carousel && prevBtn && nextBtn && items.length > 0) {
    const getStep = (): number => {
      const card = items[0];
      const gap = parseFloat(getComputedStyle(carousel).gap || '0');
      return card.offsetWidth + gap;
    };

    const update = () => {
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      const left = carousel.scrollLeft;

      prevBtn.disabled = left <= 1;
      nextBtn.disabled = left >= maxScroll - 1;

      if (currentEl) {
        const step = getStep();
        const index = Math.min(items.length - 1, Math.round(left / step));
        currentEl.textContent = String(index + 1).padStart(2, '0');
      }

      if (progressEl) {
        const visibleRatio = carousel.clientWidth / carousel.scrollWidth;
        const progress = maxScroll > 0 ? left / maxScroll : 0;
        const width = visibleRatio * 100;
        const offset = progress * (100 - width);
        progressEl.style.width = `${width}%`;
        progressEl.style.transform = `translateX(${(offset / width) * 100}%)`;
      }
    };

    prevBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      carousel.scrollBy({ left: getStep(), behavior: 'smooth' });
    });

    carousel.addEventListener('scroll', () => {
      window.requestAnimationFrame(update);
    });
    window.addEventListener('resize', update);

    document.addEventListener('keydown', (e) => {
      if (!carousel.matches(':hover') && document.activeElement !== prevBtn && document.activeElement !== nextBtn) return;
      if (e.key === 'ArrowLeft') prevBtn.click();
      if (e.key === 'ArrowRight') nextBtn.click();
    });

    update();
  }
</script>
